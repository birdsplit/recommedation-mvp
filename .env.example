# Public catalog runtime. Only the exact value `live` enables Supabase data.
# Keep `demo` until a reviewed catalog release has been published.
DATA_MODE=demo

# Supabase server-only access (required when DATA_MODE=live)
# Local: `npx supabase status -o env`의 API_URL
# Cloud: Supabase Project Settings의 project URL
SUPABASE_URL=http://127.0.0.1:55321

# `npx supabase status -o env`의 SERVICE_ROLE_KEY
# RLS를 우회하므로 절대 NEXT_PUBLIC_ 변수나 브라우저 코드에 넣지 마세요.
SUPABASE_SERVICE_ROLE_KEY=

# 관리자 로그인. 배포 환경마다 서로 다른 강한 값을 사용하세요.
ADMIN_PASSWORD=

# 관리자 세션 HMAC 서명 키. ADMIN_PASSWORD와 다른 48-byte 랜덤 값을 권장합니다.
ADMIN_COOKIE_SECRET=

# 내부 QA 링크 서명 키(16자 이상). 클라이언트가 is_test를 임의 지정하지 못하게 합니다.
STUDY_TOKEN_SECRET=
